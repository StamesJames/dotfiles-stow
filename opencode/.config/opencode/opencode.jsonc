{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "opencode-go/glm-5.2",
    },
    "build": {
      "model": "opencode-go/glm-5.2",
    },
  },
  "mcp": {
    "lean-lsp": {
      "type": "local",
      "command": [
        "uvx",
        "lean-lsp-mcp"
      ],
      "enabled": true,
    },
  },
}
